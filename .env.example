# ─── REQUIRED ─────────────────────────────────────────────────────────
# Anthropic Claude API key — used by /scan (Vision OCR), /explain, /trends
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ─── OPTIONAL ─────────────────────────────────────────────────────────
# Google Maps Places API key — used by /doctors for private clinic lookup.
# Without this, /doctors returns an empty list (NFZ public clinics still work).
# Get one at: https://console.cloud.google.com/apis/credentials
# Required APIs to enable: Places API, Geocoding API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

# Anthropic model ID. Defaults to claude-opus-4-7. Change only if you want
# to A/B against a different Claude model.
BLOODAI_MODEL_ID=claude-opus-4-7

# Vision OCR prompt version (loads prompts/scan_<version>.md). Default: v1.
BLOODAI_PROMPT_VERSION=v1

# Set to "false" to disable Opus API calls. /scan and /explain return mock
# responses; /trends falls back to a rule-based narrative. Useful for offline
# development and tests.
USE_OPUS_API=true
